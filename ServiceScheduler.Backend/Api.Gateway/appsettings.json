{
  "ReverseProxy": {
    "Routes": {
      "scheduler-openapi": {
        "ClusterId": "scheduler",
        "Match": {
          "Path": "/openapi/servicescheduler-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/openapi/{**catch-all}"
          }
        ]
      },

      "scheduler-api": {
        "ClusterId": "scheduler",
        "Match": {
          "Path": "/servicescheduler-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/servicescheduler-api"
          }
        ]
      }
    },

    "Clusters": {
      "scheduler": {
        "Destinations": {
          "default": {
            "Address": "https+http://servicescheduler-api"
          }
        }
      }
    }
  }
}